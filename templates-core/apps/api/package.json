{
  "name": "@__SCOPE__/api",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 9187 --inspector-port 9197",
    "build": "echo 'apps/api build is deploy-time via wrangler'",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@__SCOPE__/auth": "workspace:*",
    "@__SCOPE__/db": "workspace:*",
    "@__SCOPE__/notifications": "workspace:*",
    "@__SCOPE__/rpc": "workspace:*",
    "@__SCOPE__/types": "workspace:*",
    "@hono/trpc-server": "^0.4.2",
    "@sentry/cloudflare": "^10.53.1",
    "@trpc/server": "^11.17.0",
    "hono": "^4.6.16",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@__SCOPE__/config": "workspace:*",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.17.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
