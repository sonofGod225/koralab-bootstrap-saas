{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@__SCOPE__/config/tsconfig/base.json",
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    // `@__SCOPE__/notifications` est consommé par sa source (ADR 0010) et
    // contient des templates react-email `.tsx` — le JSX doit être compilable.
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
