# packages/db/.env.production — connexion DB PRODUCTION pour les migrations/seeds.
#
# Copier ce fichier en `.env.production` (gitignored) et y mettre l'URL Neon de
# PRODUCTION. Utilisé par :
#   pnpm --filter @__SCOPE__/db db:migrate:production
#   pnpm --filter @__SCOPE__/db db:seed:production
#
# ⚠️ ENVIRONNEMENT DE PRODUCTION — vérifier le backup/PITR Neon AVANT d'appliquer
# (cf. docs/setup/db-migrations.md). Ne jamais committer la vraie URL.
DATABASE_URL="postgresql://<user>:<password>@<host-prod>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
