# packages/db/.env.staging — connexion DB STAGING pour les migrations/seeds.
#
# Copier ce fichier en `.env.staging` (gitignored) et y mettre l'URL Neon de
# STAGING. Utilisé par :
#   pnpm --filter @__SCOPE__/db db:migrate:staging
#   pnpm --filter @__SCOPE__/db db:seed:staging
#
# Récupérer l'URL depuis le dashboard Neon (projet staging — connection string
# "pooled", role applicatif) OU :
#   wrangler secret list --env staging   # nom de la variable DATABASE_URL
#
# ⚠️ Ne jamais committer la vraie URL. `.env.staging` est dans .gitignore.
DATABASE_URL="postgresql://<user>:<password>@<host-staging>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
