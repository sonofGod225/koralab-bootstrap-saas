# __PROJECT_NAME__ — Variables d'environnement
# Copier vers .env.local pour dev local

# === Cloudflare ===
# CF_ACCOUNT_ID=
# CF_API_TOKEN=

# === Database (Neon Postgres) ===
# Dev: branche "dev" du projet Neon (us-east-1 pour MVP, EU Frankfurt pour staging/prod — cf. ADR 0001)
# Récupérable via console.neon.tech ou MCP : mcp__Neon__get_connection_string
# Mettre dans apps/api/.dev.vars (Wrangler dev) ET packages/db/.env (drizzle-kit migrations)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?channel_binding=require&sslmode=require

# === Better-Auth ===
BETTER_AUTH_SECRET=change-me-min-32-chars
BETTER_AUTH_URL=http://localhost:9187

# === OAuth providers ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=

# === Notifications ===
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SENDER_ID=__PROJECT_NAME__
# META_WHATSAPP_BUSINESS_PHONE_ID=
# META_WHATSAPP_TOKEN=

# === Payment Providers ===
# WAVE_API_KEY=
# WAVE_WEBHOOK_SECRET=
# PAYSTACK_SECRET_KEY=
# STRIPE_SECRET_KEY=
# FLUTTERWAVE_SECRET_KEY=

# === IA Providers ===
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# === FNE Côte d'Ivoire (DGI) ===
# FNE_TEST_URL=http://54.247.95.108/ws
# FNE_PRODUCTION_URL=https://...

# === Observabilité ===
# Story 1.6 — Sentry. DSN publics (non secrets) — 1 projet Sentry par app.
# apps/api : binding Worker SENTRY_DSN (apps/api/.dev.vars en local).
# apps/suite + apps/admin : VITE_SENTRY_DSN (inliné au build, voir apps/*/.env.*).
# SENTRY_DSN=https://<key>@o<org>.ingest.<region>.sentry.io/<project>
# VITE_SENTRY_DSN=https://<key>@o<org>.ingest.<region>.sentry.io/<project>
# Upload source maps (CI uniquement) :
# SENTRY_AUTH_TOKEN=
# AXIOM_TOKEN=
# AXIOM_DATASET=
# POSTHOG_API_KEY=

# === App ===
VITE_API_URL=http://localhost:9187
NODE_ENV=development
