    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@__SCOPE__/config": "workspace:*",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
